# Vision-RAG-CXR server configuration example
# Copy to .env only if you want to source these values manually.

# Indiana University Chest X-ray dataset paths
INDIANA_IMAGE_DIR=/root/data/images/images_normalized
INDIANA_REPORT_CSV=/root/data/label/indiana_reports.csv

# Optional external CheXbert installation
CHEXBERT_DIR=/root/CheXbert
CHEXBERT_CHECKPOINT=/root/CheXbert/chexbert.pth

# Hugging Face cache / model loading
HF_HOME=/root/.cache/huggingface
TRANSFORMERS_CACHE=/root/.cache/huggingface

# GPU selection examples
GPU_IDS=1,2,3,4,6
CHEXBERT_GPU=1

# Smoke settings
SAMPLE_SIZE=8
ABNORMAL_FRACTION=0.5
